# Database (local pgAdmin)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/studentlife
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studentlife
DB_USER=postgres
DB_PASSWORD=YOUR_PASSWORD

# Redis (Upstash REST — free at upstash.com)
REDIS_URL=https://your-instance.upstash.io
REDIS_TOKEN=your-upstash-token

# JWT
JWT_SECRET=generate-a-long-random-string-here
JWT_EXPIRES_IN=7d

# AI Provider — Groq (free tier: 14,400 req/day, no credit card needed)
# Get your free key at: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...
AI_MODEL=llama-3.1-8b-instant

# OpenWeatherMap (optional — free tier at openweathermap.org/api)
# App works without this — weather falls back to wttr.in (no key needed)
OPENWEATHER_API_KEY=

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000
